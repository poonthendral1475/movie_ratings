<div class="crd-center d-flex justify-content-center">
  <%= render @movie %>
</div>

<div class="d-flex justify-content-center gap-3 mt-5 show-form">
  <%= link_to "Edit", edit_movie_path(@movie), class:"click btn btn-secondary" %>
  <%= link_to "<- Back", movies_path, class:"click btn btn-outline-danger" %>

</div>
<div class="d-flex justify-content-center mt-3">
  <%= button_to "Destroy this movie", @movie, method: :delete, class:"destroy-btn btn btn-danger" %>
</div>
